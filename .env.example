VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Both optional — the app is a complete no-op for each until set (no SDK is
# even downloaded). See README §6 DO-6.
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Cal.com event type booking URL — public, safe to expose client-side.
# Falls back to a "not configured yet" message in the wizard/dashboard
# until set. See README §5.B.
VITE_CAL_BOOKING_LINK=

# Server-side only (Supabase Edge Functions) — NEVER exposed to the client,
# never committed with real values. Set via `supabase secrets set`, not here.
SUPABASE_SERVICE_ROLE_KEY=
# Powers Kairos Mind, the in-lesson AI tutor (supabase/functions/kairos-mind-tutor).
ANTHROPIC_API_KEY=
RESEND_API_KEY=
NOTIFY_WEBHOOK_SECRET=
# Stripe Checkout (create-checkout-session, stripe-webhook). See README §5.C/§6 DO-1.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ALLOWED_CHECKOUT_ORIGINS=
# Verifies Cal.com's webhook calls (cal-webhook). See README §5.B.
CAL_WEBHOOK_SECRET=

# Used only by scripts/db-backup.sh, scripts/db-restore.sh, and the
# scheduled backup workflow (.github/workflows/backup.yml) — not read by
# the app itself. Supabase dashboard: Settings > Database > Connection
# string > URI (use the pooler URI for the CI/scheduled job).
DATABASE_URL=
